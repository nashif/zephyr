&spi0 {
	pw,cs-mode = <0>;
	pw,cs-output = <0>;
	status = "okay";

	slow@0 {
		compatible = "test-spi-loopback-slow";
		reg = <0>;
		spi-max-frequency = <500000>;
	};

	fast@0 {
		compatible = "test-spi-loopback-fast";
		reg = <0>;
		spi-max-frequency = <16000000>;
	};
};

&gpio_e {
	status = "okay";
};

&gpio_b {
	status = "okay";
};

/ {
	resources {
		compatible = "test-gpio-basic-api";
		out-gpios = <&gpio_b 22 0>;
		in-gpios = <&gpio_b 23 0>;
	};
};
