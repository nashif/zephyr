tst_dma0: &edma {};

#include <zephyr/dt-bindings/memory-attr/memory-attr-arm.h>

/ {
	soc {
		sram_nocache: memory@21070000 {
			compatible = "zephyr,memory-region", "mmio-sram";
			reg = <0x21070000 DT_SIZE_K(64)>;
			zephyr,memory-region = "SRAMNOCACHE";
			zephyr,memory-attr = <DT_MEM_ARM(ATTR_MPU_RAM_NOCACHE)>;
		};
	};
};

&sram0 {
	compatible = "mmio-sram";
	reg = <0x21000000 DT_SIZE_K(448)>;
};

&pinctrl {
	lpspi3_default: lpspi3_default {
		group0 {
			pinmux = <PO0_LPSPI3_SOUT_O>, <PO14_LPSPI3_SCK_O>;
			output-enable;
		};
		group1 {
			pinmux = <PO11_LPSPI3_SIN_I>;
			input-enable;
		};
	};
};

&lpspi3 {
	status = "okay";
	pinctrl-0 = <&lpspi3_default>;
	pinctrl-names = "default";
	pcs-sck-delay = <1000>;
	sck-pcs-delay = <1000>;
	transfer-delay = <1000>;
	slow@0 {
		compatible = "test-spi-loopback-slow";
		reg = <0>;
		spi-max-frequency = <500000>;
	};
	fast@0 {
		compatible = "test-spi-loopback-fast";
		reg = <0>;
		spi-max-frequency = <5000000>;
	};
};
