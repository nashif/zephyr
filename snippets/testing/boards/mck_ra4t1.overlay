tst_dma0: &dma0 {
	status = "okay";
	interrupts = <95 1>, <94 1>, <93 1>;
	interrupt-names = "ch0", "ch1", "ch2";
};

&spi0 {
	rx-dtc;
	tx-dtc;
	status = "okay";
	slow@0 {
		compatible = "test-spi-loopback-slow";
		reg = <0>;
		spi-max-frequency = <2000000>;
	};
	fast@0 {
		compatible = "test-spi-loopback-fast";
		reg = <0>;
		spi-max-frequency = <3000000>;
	};
};
