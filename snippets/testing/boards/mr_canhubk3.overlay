tst_dma0: &edma0 {};

&lpspi1 {
	status = "okay";
	dmas = <&edma0 10 45>, <&edma0 12 46>;
	dma-names = "tx", "rx";
	slow@0 {
		compatible = "test-spi-loopback-slow";
		reg = <0>;
		spi-max-frequency = <500000>;
	};
	fast@0 {
		compatible = "test-spi-loopback-fast";
		reg = <0>;
		spi-max-frequency = <5000000>;
	};
};
